<!-- Scroll To Top -->
<button id="scrollTopBtn" aria-label="Kembali ke atas"
    class="fixed bottom-6 right-6 z-40 w-11 h-11 rounded-full bg-accent/20 hover:bg-accent/30 border border-accent/30 text-accent hidden items-center justify-center transition-all shadow-lg backdrop-blur-md">
    <i data-lucide="arrow-up" class="w-5 h-5"></i>
</button>

<script>
    (function () {
        try {
            const btn = document.getElementById('scrollTopBtn');
            if (!btn) return;
            const onScroll = () => {
                if (window.scrollY > 400) {
                    btn.classList.remove('hidden');
                    btn.classList.add('flex');
                } else {
                    btn.classList.add('hidden');
                    btn.classList.remove('flex');
                }
            };
            window.addEventListener('scroll', onScroll, { passive: true });
            btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        } catch (_) { }
    })();
</script>


<!-- About Section -->
<section id="tentang" class="relative overflow-hidden py-24">
    <div class="pointer-events-none absolute -top-24 -right-16 w-80 h-80 bg-accent/20 blur-3xl rounded-full"></div>
    <div class="pointer-events-none absolute bottom-0 -left-10 w-96 h-96 bg-teal-500/10 blur-3xl rounded-full"></div>
    <svg class="pointer-events-none absolute inset-0 opacity-[0.05]" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="grid" width="32" height="32" patternUnits="userSpaceOnUse"><path d="M 32 0 L 0 0 0 32" fill="none" stroke="white" stroke-width="0.5" /></pattern></defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-12" data-aos="fade-up">
            <span class="text-gray-400 text-lg">Tentang</span>
            <h2 class="font-outfit font-bold text-4xl sm:text-5xl"><span class="text-accent">Saya</span></h2>
        </div>

        <p class="text-xl sm:text-2xl font-outfit font-medium text-white mb-8 md:max-w-5xl" data-aos="fade-up" data-aos-delay="100">
            <%= profile?.bio?.split('.')[0] || 'Perpaduan logika kode dan estetika desain.' %>.
        </p>

        <div class="grid lg:grid-cols-1 gap-12">
            <div class="relative overflow-hidden space-y-6 md:bg-white/5 md:border md:border-white/10 md:rounded-2xl md:p-6 md:shadow-lg md:shadow-black/20" data-aos="fade-right">
                <% const aboutImg=(profile && (profile.aboutImage || profile.avatarUrl)) ? (profile.aboutImage || profile.avatarUrl) : null; %>
                <% if (aboutImg) { %>
                    <img src="<%= aboutImg %>" class="hidden md:block absolute top-6 right-6 w-28 h-28 rounded-xl object-cover border border-white/10 opacity-90">
                <% } %>
                <div class="h-1 rounded-full bg-gradient-to-r from-accent/60 via-accent/20 to-transparent"></div>
                <p class="text-gray-300 leading-relaxed"><%= profile?.bio || 'Perjalanan saya di dunia digital dimulai sejak bangku sekolah.' %></p>
                <div class="flex flex-wrap gap-2">
                    <% let _skillsFlat=[]; if (locals.skillCategories) {
                        Object.entries(skillCategories).forEach(([c,arr])=>{
                        (arr||[]).forEach(s=>_skillsFlat.push({n:s.name,p:s.percentage})); });
                        _skillsFlat.sort((a,b)=> (b.p||0)-(a.p||0)); } %>
                    <% (_skillsFlat||[]).slice(0,6).forEach(s=>{ %>
                        <span class="px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-medium transition-all duration-300 hover:bg-accent/20 hover:text-accent/90"><%= s.n %></span>
                    <% }) %>
                </div>
                <div>
                    <a href="#kontak" class="inline-flex items-center gap-2 px-4 py-2 bg-accent/20 hover:bg-accent/30 text-accent border border-accent/30 rounded-xl transition-colors">
                        <i data-lucide="message-circle" class="w-4 h-4"></i><span>Hubungi Saya</span>
                    </a>
                </div>

                <div class="flex gap-8 pt-6">
                    <div>
                        <div class="font-outfit font-bold text-3xl sm:text-4xl text-white">2+</div>
                        <div class="text-sm text-gray-500 mt-1">Tahun Pengalaman</div>
                    </div>
                    <div>
                        <div class="font-outfit font-bold text-3xl sm:text-4xl text-white"><%= projects?.length || 0 %>+</div>
                        <div class="text-sm text-gray-500 mt-1">Proyek Selesai</div>
                    </div>
                </div>

                <!-- Tabs Content -->
                <div class="mt-12 relative z-10">
                    <div class="inline-flex flex-wrap gap-1 bg-white/5 border border-white/10 rounded-2xl p-1 mb-4" role="tablist">
                        <button id="tab-experience" data-tab="experience" class="tab-btn active px-4 py-2 rounded-xl text-sm font-medium bg-accent/20 text-accent transition-all inline-flex items-center gap-2" role="tab" aria-selected="true" aria-controls="content-experience">
                            <i data-lucide="briefcase" class="w-4 h-4"></i><span>Pengalaman</span>
                        </button>
                        <button id="tab-education" data-tab="education" class="tab-btn px-4 py-2 rounded-xl text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all inline-flex items-center gap-2" role="tab" aria-selected="false" aria-controls="content-education">
                            <i data-lucide="graduation-cap" class="w-4 h-4"></i><span>Pendidikan</span>
                        </button>
                        <button id="tab-achievements" data-tab="achievements" class="tab-btn px-4 py-2 rounded-xl text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all inline-flex items-center gap-2" role="tab" aria-selected="false" aria-controls="content-achievements">
                            <i data-lucide="trophy" class="w-4 h-4"></i><span>Pencapaian</span>
                        </button>
                        <button id="tab-organizations" data-tab="organizations" class="tab-btn px-4 py-2 rounded-xl text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all inline-flex items-center gap-2" role="tab" aria-selected="false" aria-controls="content-organizations">
                            <i data-lucide="users" class="w-4 h-4"></i><span>Organisasi</span>
                        </button>
                        <button id="tab-skills" data-tab="skills" class="tab-btn px-4 py-2 rounded-xl text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all inline-flex items-center gap-2" role="tab" aria-selected="false" aria-controls="content-skills">
                            <i data-lucide="sparkles" class="w-4 h-4"></i><span>Keterampilan</span>
                        </button>
                        <button id="tab-publications" data-tab="publications" class="tab-btn px-4 py-2 rounded-xl text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all inline-flex items-center gap-2" role="tab" aria-selected="false" aria-controls="content-publications">
                            <i data-lucide="book-open" class="w-4 h-4"></i><span>Publikasi</span>
                        </button>
                    </div>
                    
                    <div class="tab-panel bg-white/5 border border-white/10 rounded-2xl p-5 backdrop-blur-md shadow-xl ring-1 ring-white/10">
                        <!-- Experience -->
                        <div id="content-experience" class="tab-content space-y-8 animate-fade-in block" role="tabpanel" aria-labelledby="tab-experience">
                            <% if (locals.experiences) { experiences.forEach(exp => { %>
                                <div class="relative pl-8 border-l border-white/10 group hover:border-accent/50 transition-colors">
                                    <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-accent/20 border border-accent group-hover:scale-110 transition-transform"></div>
                                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
                                        <h4 class="text-lg font-bold text-white group-hover:text-accent transition-colors"><%= exp.position %></h4>
                                        <span class="text-sm text-accent bg-accent/10 px-3 py-1 rounded-full w-fit mt-2 sm:mt-0"><%= exp.period %></span>
                                    </div>
                                    <p class="text-base text-gray-300 font-medium mb-2"><%= exp.company %></p>
                                    <p class="text-sm text-gray-400 leading-relaxed"><%= exp.description || '' %></p>
                                </div>
                            <% })} %>
                        </div>

                        <!-- Education -->
                        <div id="content-education" class="tab-content hidden space-y-8 animate-fade-in" role="tabpanel" aria-labelledby="tab-education">
                            <% if (locals.education) { education.forEach(edu => { %>
                                <div class="relative pl-8 border-l border-white/10 group hover:border-accent/50 transition-colors">
                                    <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-teal-500/20 border border-teal-500 group-hover:scale-110 transition-transform"></div>
                                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
                                        <h4 class="text-lg font-bold text-white group-hover:text-teal-400 transition-colors"><%= edu.institution %></h4>
                                        <span class="text-sm text-teal-400 bg-teal-500/10 px-3 py-1 rounded-full w-fit mt-2 sm:mt-0"><%= edu.period %></span>
                                    </div>
                                    <p class="text-base text-gray-300 font-medium mb-2"><%= edu.degree %></p>
                                    <p class="text-sm text-gray-400"><%= edu.major %></p>
                                </div>
                            <% })} %>
                        </div>

                        <!-- Achievements -->
                        <div id="content-achievements" class="tab-content hidden space-y-6 animate-fade-in" role="tabpanel" aria-labelledby="tab-achievements">
                            <% if (locals.awards && awards.length > 0) { awards.forEach(a => { %>
                                <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:border-accent/30 transition-colors">
                                    <div class="flex items-start gap-4">
                                        <% if (a.certificateUrl) { %>
                                            <a href="<%= a.certificateUrl %>" target="_blank" class="shrink-0"><img src="<%= a.certificateUrl %>" alt="<%= a.title %>" class="w-16 h-16 object-cover rounded-lg border border-white/10" loading="lazy"></a>
                                        <% } else { %>
                                            <div class="w-16 h-16 rounded-lg bg-white/10 flex items-center justify-center shrink-0"><i data-lucide="award" class="w-8 h-8 text-accent/50"></i></div>
                                        <% } %>
                                        <div>
                                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                                <h3 class="font-outfit font-semibold text-white text-base"><%= a.title %></h3>
                                                <span class="text-xs text-accent bg-accent/10 px-2 py-0.5 rounded"><%= a.date %></span>
                                            </div>
                                            <p class="text-sm text-gray-400 mb-1"><%= a.organizer %></p>
                                            <% if (a.description) { %><p class="text-xs text-gray-500 line-clamp-2"><%= a.description %></p><% } %>
                                        </div>
                                    </div>
                                </div>
                            <% })} else { %><p class="text-gray-500 italic">Belum ada pencapaian.</p><% } %>
                        </div>

                        <!-- Organizations -->
                        <div id="content-organizations" class="tab-content hidden space-y-6 animate-fade-in" role="tabpanel" aria-labelledby="tab-organizations">
                            <% if (locals.organizations && organizations.length > 0) { organizations.forEach(org => { %>
                                <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:border-accent/30 transition-colors">
                                    <div class="flex items-start gap-4">
                                        <% if (org.logoUrl) { %>
                                            <img src="<%= org.logoUrl %>" alt="<%= org.name %>" class="w-12 h-12 rounded-lg object-cover border border-white/10" loading="lazy">
                                        <% } else { %>
                                            <div class="w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center"><i data-lucide="users" class="w-6 h-6 text-accent/60"></i></div>
                                        <% } %>
                                        <div>
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <h3 class="font-outfit font-semibold text-white"><%= org.name %></h3>
                                                <span class="text-xs text-accent bg-accent/10 px-2 py-0.5 rounded"><%= org.period %></span>
                                            </div>
                                            <p class="text-sm text-gray-300 font-medium mt-1"><%= org.role %></p>
                                            <% if (org.description) { %><p class="text-sm text-gray-400 mt-1"><%= org.description %></p><% } %>
                                        </div>
                                    </div>
                                </div>
                            <% })} else { %><p class="text-gray-500 italic">Belum ada organisasi.</p><% } %>
                            <div class="pt-2"><a href="/organizations" class="inline-flex items-center gap-2 text-accent">Lihat semua organisasi <i data-lucide="arrow-right" class="w-4 h-4"></i></a></div>
                        </div>

                        <!-- Skills -->
                        <div id="content-skills" class="tab-content hidden space-y-4 animate-fade-in" role="tabpanel" aria-labelledby="tab-skills">
                            <div class="flex items-center justify-between"><h3 class="font-outfit font-semibold text-lg">Kreativitas & Tech Stack</h3><a href="/skills" class="text-accent text-sm inline-flex items-center gap-1">Lihat semua <i data-lucide="arrow-right" class="w-4 h-4"></i></a></div>
                            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                                <% if (locals.skillCategories) { Object.entries(skillCategories).forEach(([category, skills]) => { skills.forEach(skill => { %>
                                    <div class="tech-card">
                                        <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center mb-3 text-accent"><span class="font-bold"><%= skill.name.charAt(0) %></span></div>
                                        <h4 class="font-medium text-sm"><%= skill.name %></h4>
                                        <p class="text-xs text-gray-500 mt-0.5 capitalize"><%= category %></p>
                                        <div class="w-full bg-white/10 h-1 mt-2 rounded-full overflow-hidden"><div class="bg-accent h-full" style="width: <%= skill.percentage %>%"></div></div>
                                    </div>
                                <% })})} %>
                            </div>
                        </div>

                        <!-- Publications -->
                        <div id="content-publications" class="tab-content hidden space-y-6 animate-fade-in" role="tabpanel" aria-labelledby="tab-publications">
                            <% if (locals.publications && publications.length > 0) { publications.slice(0,3).forEach(p => { %>
                                <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:border-accent/30 transition-colors">
                                    <div class="flex items-start gap-4">
                                        <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" alt="<%= p.title %>" class="w-16 h-16 rounded-lg object-cover border border-white/10" loading="lazy"><% } %>
                                        <div class="flex-1">
                                            <div class="flex items-center justify-between gap-2">
                                                <span class="text-xs text-accent bg-accent/10 px-2 py-0.5 rounded"><%= p.outlet %></span>
                                                <span class="text-xs text-gray-400"><%= p.date %></span>
                                            </div>
                                            <h4 class="text-white font-semibold mt-1"><%= p.title %></h4>
                                            <% if (p.url) { %><a href="<%= p.url %>" target="_blank" class="inline-flex items-center gap-2 text-accent mt-1 text-sm">Baca <i data-lucide="arrow-up-right" class="w-4 h-4"></i></a><% } %>
                                        </div>
                                    </div>
                                </div>
                            <% })} else { %><p class="text-gray-500 italic">Belum ada publikasi.</p><% } %>
                            <div class="pt-2"><a href="/publications" class="inline-flex items-center gap-2 text-accent">Lihat semua publikasi <i data-lucide="arrow-right" class="w-4 h-4"></i></a></div>
                        </div>
                    </div>
                </div>
                
                <!-- Realtime Scripts (Only if enabled) -->
                <% if (locals.realtimeEnabled) { %>
                    <script src="/socket.io/socket.io.js"></script>
                    <script>
                        (function(){
                            try {
                                const socket = io({transports:['websocket','polling']});
                                function escapeHtml(u){return String(u).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");}
                                function renderExps(exps){
                                    const c = document.getElementById('content-experience'); if(!c) return;
                                    if(!exps.length){ c.innerHTML='<p class="text-gray-500">Belum ada pengalaman.</p>'; return; }
                                    c.innerHTML = exps.map(e => `
                                        <div class="relative pl-8 border-l border-white/10 group hover:border-accent/50 transition-colors">
                                            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-accent/20 border border-accent group-hover:scale-110 transition-transform"></div>
                                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
                                                <h4 class="text-lg font-bold text-white group-hover:text-accent transition-colors">${escapeHtml(e.position)}</h4>
                                                <span class="text-sm text-accent bg-accent/10 px-3 py-1 rounded-full w-fit mt-2 sm:mt-0">${escapeHtml(e.period)}</span>
                                            </div>
                                            <p class="text-base text-gray-300 font-medium mb-2">${escapeHtml(e.company)}</p>
                                            <p class="text-sm text-gray-400 leading-relaxed">${escapeHtml(e.description||'')}</p>
                                        </div>`).join('');
                                }
                                socket.on('experience:update', d => renderExps(d||[]));
                                fetch('/api/experiences').then(r=>r.json()).then(d=>d.experiences&&renderExps(d.experiences));
                            }catch(e){}
                        })();
                    </script>
                <% } %>
                
                <a href="<%= profile?.cvLink %>" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-accent/30 rounded-xl transition-all mt-4">
                    <i data-lucide="download" class="w-5 h-5 text-accent"></i><span>Unduh CV</span>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Tab Script -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    function switchTab(id) {
        tabs.forEach(b => {
            if(b.dataset.tab === id){ b.classList.add('bg-accent/20', 'text-accent', 'active'); b.classList.remove('text-gray-400'); b.setAttribute('aria-selected','true'); }
            else { b.classList.remove('bg-accent/20', 'text-accent', 'active'); b.classList.add('text-gray-400'); b.setAttribute('aria-selected','false'); }
        });
        contents.forEach(c => {
            if(c.id === 'content-'+id){ c.classList.remove('hidden'); c.classList.add('block'); }
            else { c.classList.add('hidden'); c.classList.remove('block'); }
        });
    }
    tabs.forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));
});
</script>

<footer class="py-8 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <span class="font-outfit font-bold text-xl">Ridhopasii<span class="text-accent">.</span></span>
            </div>

            <p class="text-sm text-gray-500">
                © <%= new Date().getFullYear() %>
                    <%= profile?.fullName || 'Ridhopasii' %>. All rights reserved.
            </p>

            <div class="flex items-center gap-4">
                <% socials.forEach(social=> { %>
                    <a href="<%= social.url %>" target="_blank"
                        class="text-gray-500 hover:text-accent transition-colors">
                        <i data-lucide="<%= social.icon %>" class="w-5 h-5"></i>
                    </a>
                    <% }) %>
            </div>
        </div>
    </div>
</footer>

<!-- Scripts are now consolidated in header.ejs and separate JS files -->
<script src="/js/accessibility.js"></script>
<script src="/js/toast.js"></script>
<script src="/js/loadingStates.js"></script>

<script>
    // Initialize Lucide once at the very end
    window.addEventListener('load', () => {
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    });
</script>
</body>
</html>
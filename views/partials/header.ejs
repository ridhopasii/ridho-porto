                            </div>
                        </div>

                        <!-- Secondary Links -->
                        <div class="space-y-4 pt-8 border-t border-white/5">
                            <p class="text-xs font-bold text-gray-500 tracking-[0.2em] uppercase">Eksplor Lebih Jauh</p>
                            <div class="grid grid-cols-2 gap-4">
                                <a href="/organizations" class="text-lg text-gray-400 hover:text-white transition-colors flex items-center gap-2">
                                    <i data-lucide="users" class="w-4 h-4"></i> Organisasi
                                </a>
                                <a href="/skills" class="text-lg text-gray-400 hover:text-white transition-colors flex items-center gap-2">
                                    <i data-lucide="sparkles" class="w-4 h-4"></i> Keterampilan
                                </a>
                                <a href="/publications" class="text-lg text-gray-400 hover:text-white transition-colors flex items-center gap-2">
                                    <i data-lucide="book-open" class="w-4 h-4"></i> Publikasi
                                </a>
                                <a href="/blog" class="text-lg text-gray-400 hover:text-white transition-colors flex items-center gap-2">
                                    <i data-lucide="pen-tool" class="w-4 h-4"></i> Blog
                                </a>
                                <a href="/awards" class="text-lg text-gray-400 hover:text-white transition-colors flex items-center gap-2">
                                    <i data-lucide="award" class="w-4 h-4"></i> Awards
                                </a>
                                <a href="/#kontak" class="text-lg text-gray-400 hover:text-white transition-colors flex items-center gap-2">
                                    <i data-lucide="mail" class="w-4 h-4"></i> Kontak

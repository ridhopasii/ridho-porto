                        </div>

                        <!-- Footer Info in Menu -->
                        <div class="flex items-center justify-between pt-8 border-t border-white/5">
                            <div class="flex gap-4">
                                <% if (locals.socials) { socials.slice(0, 3).forEach(social => { %>
                                    <a href="<%= social.url %>" target="_blank" class="text-gray-500 hover:text-accent transition-colors">
                                        <i data-lucide="<%= social.icon %>" class="w-5 h-5"></i>
                                    </a>
                                <% }) } %>

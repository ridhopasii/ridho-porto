                        </div>
                    </div>

                    <!-- Right: Info & Settings -->
                    <div class="flex flex-col justify-between space-y-12">
                        <div class="space-y-8">
                            <div class="p-8 rounded-3xl bg-white/[0.03] border border-white/5">
                                <h3 class="font-outfit font-bold text-xl mb-4">Mari Berkolaborasi</h3>
                                <p class="text-gray-400 mb-6 text-sm leading-relaxed">
                                    Punya ide menarik? Saya selalu terbuka untuk diskusi proyek baru atau sekadar berbagi pengalaman.
                                </p>
                                <a href="/#kontak" class="inline-flex items-center gap-2 text-accent font-bold group">
                                    <span>Kirim Pesan</span>
                                    <i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i>
                                </a>
                            </div>

                            <div class="flex items-center gap-4 px-4">
                                <span class="text-sm font-medium text-gray-500">Bahasa:</span>
                                <button class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-accent/10 text-accent text-sm font-bold border border-accent/20">
                                    <i data-lucide="globe" class="w-4 h-4"></i>
                                    <span>ID</span>
                                </button>
                                <button class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-gray-500 text-sm font-medium hover:text-white transition-colors">
                                    <span>EN</span>
                                </button>

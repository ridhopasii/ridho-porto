generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Profile {
  id              Int     @id @default(autoincrement())
  name            String
  fullName        String?
  title           String?
  bio             String?
  location        String?
  email           String?
  phone           String?
  whatsappUrl     String?
  cvLink          String?
  avatarUrl       String?
  heroImage       String?
  aboutImage      String?
  badge           String?
  status_text     String?
  quote           String?
  about_tag       String?
  about_title     String?
  education_level String?
  availability    String?
  github_url      String?
  linkedin_url    String?
  instagram_url   String?
  twitter_url     String?
  tiktok_url      String?
  facebook_url    String?
  footer_title    String?
  footer_sub      String?
  images          Json?   // Multi-photo for profile/avatar
}

model Experience {
  id          Int      @id @default(autoincrement())
  company     String
  position    String
  period      String
  description String?
  order       Int      @default(0)
  images      Json?    // Documentation photos
  proofUrl    String?  // Hyperlink proof
}

model Education {
  id          Int      @id @default(autoincrement())
  institution String
  degree      String
  major       String
  period      String
  status      String?
  order       Int      @default(0)
  images      Json?    // Documentation photos
  proofUrl    String?  // Hyperlink proof
}

model Skill {
  id          Int     @id @default(autoincrement())
  name        String
  category    String? // hardskill, softskill, bahasa
  level       String? // Beginner, Intermediate, Advanced, Expert
  percentage  Int?
  icon        String? // Lucide icon name or image url
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique @default(cuid())
  description String
  content     String?
  imageUrl    String?
  images      Json?    // Multi-photo
  projectUrl  String?
  repoUrl     String?
  tags        String
  category    String   @default("project")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Organization {
  id          Int      @id @default(autoincrement())
  name        String
  role        String
  period      String
  description String?
  logoUrl     String?
  images      Json?    // Documentation photos
  website     String?
  order       Int      @default(0)
}

model Publication {
  id          Int      @id @default(autoincrement())
  title       String
  outlet      String
  date        String
  url         String?
  description String?
  imageUrl    String?
  images      Json?    // Multi-photo
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Award {
  id             Int      @id @default(autoincrement())
  title          String
  organizer      String
  date           String
  description    String?
  certificateUrl String?
  images         Json?    // Documentation photos
  proofUrl       String?  // Hyperlink proof
  category       String?
  credentialId   String?
}

model Gallery {
  id          Int      @id @default(autoincrement())
  title       String
  category    String   // kegiatan, prestasi, dll
  images      Json?    // Multi-photo
  date        String?
  description String?
  createdAt   DateTime @default(now())
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String
  imageUrl    String?
  images      Json?    // Multi-photo
  tags        String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Social {
  id       Int    @id @default(autoincrement())
  platform String
  url      String
  icon     String
  userId   Int?
}

model Testimonial {
  id          Int      @id @default(autoincrement())
  name        String
  role        String
  message     String
  avatarUrl   String?
  createdAt   DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

